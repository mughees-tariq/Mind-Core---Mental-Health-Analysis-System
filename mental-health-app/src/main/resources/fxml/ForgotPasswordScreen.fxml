<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<BorderPane xmlns="http://javafx.com/javafx/8"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.mentalhealth.controller.ForgotPasswordController"
            prefWidth="1200" prefHeight="800"
            stylesheets="@../css/styles.css">

    <!-- LEFT BRAND PANEL -->
    <left>
        <VBox prefWidth="350" styleClass="login-left">
            <padding>
                <Insets top="40" right="35" bottom="40" left="35"/>
            </padding>

            <Label text="  Mental Health" styleClass="login-left-title"/>
            <Label text="   AI-powered mental wellness companion"
                   styleClass="login-left-subtitle"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Label text="Secure Account Recovery"
                   wrapText="true"
                   style="-fx-font-size: 18px; -fx-font-weight: bold;
                          -fx-text-fill: white; -fx-line-spacing: 3;"/>

            <Label text="Verify your identity using your security question to regain access to your account."
                   wrapText="true"
                   style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.75);
                          -fx-line-spacing: 3; -fx-padding: 14 0 0 0;"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Label text="Track • Analyze • Improve"
                   styleClass="login-left-footnote"
                   style="-fx-font-size: 22px; -fx-font-weight: bold"/>
        </VBox>
    </left>

    <!-- CENTER PASSWORD RECOVERY CARD -->
    <center>
        <VBox alignment="CENTER" spacing="18" styleClass="login-center-wrap">
            <!-- PASSWORD RECOVERY CARD -->
            <VBox spacing="14" maxWidth="440" styleClass="card login-card">

                <!-- Title -->
                <Label fx:id="titleLabel" 
                       text="Recover Your Account"
                       styleClass="login-title"/>
                <Label fx:id="subtitleLabel"
                       text="Enter your username to get started"
                       styleClass="login-subtitle"/>

                <!-- Error Label -->
                <Label fx:id="errorLabel"
                    visible="false"
                    styleClass="error-text"/>

                <!-- Stage 1: Enter Username -->
                <VBox fx:id="stage1Container" spacing="6">
                    <Label text="Username" styleClass="form-label"/>
                    <TextField fx:id="usernameField"
                            promptText="Enter your username"
                            prefHeight="42"
                            onAction="#handleStage1"/>
                </VBox>

                <!-- Stage 2: Security Question -->
                <VBox fx:id="stage2Container" spacing="6" visible="false" managed="false">
                    <Label text="Security Question" styleClass="form-label"/>
                    <TextArea fx:id="securityQuestionDisplay"
                            prefRowCount="2" wrapText="true"
                            editable="false"
                            style="-fx-control-inner-background: #f0f0f0;
                                   -fx-font-size: 13px;
                                   -fx-padding: 12px;"/>
                    
                    <Label text="Your Answer" styleClass="form-label" style="-fx-padding: 10 0 0 0;"/>
                    <TextField fx:id="securityAnswerField"
                            promptText="Enter your security answer"
                            prefHeight="42"
                            onAction="#handleStage2"/>
                    
                    <Label text="💡 Answer is case-insensitive"
                           style="-fx-font-size: 11px; -fx-text-fill: #64748b;"/>
                </VBox>

                <!-- Stage 3: Set New Password -->
                <VBox fx:id="stage3Container" spacing="6" visible="false" managed="false">
                    <Label text="New Password" styleClass="form-label"/>
                    <HBox spacing="10" alignment="CENTER">
                        <PasswordField fx:id="newPasswordField"
                                       promptText="Min 8 chars, letters &amp; numbers"
                                       prefHeight="42" HBox.hgrow="ALWAYS"
                                       styleClass="register-input"/>
                        <TextField fx:id="newPasswordFieldVisible"
                                   promptText="Min 8 chars, letters &amp; numbers"
                                   prefHeight="42" HBox.hgrow="ALWAYS"
                                   styleClass="register-input"
                                   visible="false" managed="false"/>
                        <CheckBox fx:id="showPasswordCheck"
                                  text="👁"
                                  onAction="#togglePasswordVisibility"
                                  style="-fx-cursor: hand; -fx-font-size: 16px;"/>
                    </HBox>

                    <Label text="Confirm Password" styleClass="form-label"/>
                    <HBox spacing="10" alignment="CENTER">
                        <PasswordField fx:id="confirmPasswordField"
                                       promptText="Re-enter your password"
                                       prefHeight="42" HBox.hgrow="ALWAYS"
                                       styleClass="register-input"/>
                        <TextField fx:id="confirmPasswordFieldVisible"
                                   promptText="Re-enter your password"
                                   prefHeight="42" HBox.hgrow="ALWAYS"
                                   styleClass="register-input"
                                   visible="false" managed="false"/>
                        <CheckBox fx:id="showConfirmPasswordCheck"
                                  text="👁"
                                  onAction="#toggleConfirmPasswordVisibility"
                                  style="-fx-cursor: hand; -fx-font-size: 16px;"/>
                    </HBox>
                </VBox>

                <!-- Button Container -->
                <HBox fx:id="buttonContainer" spacing="10" alignment="CENTER">
                    <Button fx:id="nextButton"
                            text="Continue"
                            onAction="#handleStage1"
                            prefWidth="200"
                            prefHeight="42"
                            styleClass="primary-button"/>
                    <Button fx:id="backButton"
                            text="← Back"
                            onAction="#handleBack"
                            prefWidth="100"
                            prefHeight="42"
                            styleClass="secondary-button"
                            visible="false"
                            managed="false"/>
                </HBox>

                <!-- Back to Login -->
                <HBox alignment="CENTER" spacing="6">
                    <Label text="Remember your password?"
                        styleClass="muted-text"/>
                    <Hyperlink text="Sign In →"
                            onAction="#handleBackToLogin"
                            styleClass="login-link"/>
                </HBox>

            </VBox>
        </VBox>
    </center>

</BorderPane>
