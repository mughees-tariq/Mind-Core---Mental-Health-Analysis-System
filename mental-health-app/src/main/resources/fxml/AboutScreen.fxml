<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:id="root"
            fx:controller="com.mentalhealth.controller.AboutController"
            prefWidth="1200" prefHeight="800">

    <!-- Sidebar -->
    <left>
        <VBox prefWidth="250" spacing="5"
              style="-fx-background-color: #1565C0;">
            <padding>
                <Insets top="20" right="15" bottom="20" left="15"/>
            </padding>

            <Label text="Mental Health"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>

            <Region prefHeight="30"/>

            <Button text="&#x1F4CA;  Dashboard"
                    onAction="#handleDashboard"
                    prefWidth="Infinity" prefHeight="45"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;"/>

            <Button text="&#x1F4DD;  New Analysis"
                    onAction="#handleNewAnalysis"
                    prefWidth="Infinity" prefHeight="45"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;"/>

            <Button text="&#x1F4DC;  History"
                    onAction="#handleHistory"
                    prefWidth="Infinity" prefHeight="45"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;"/>

            <Button text="&#x1F60A;  Mood Tracker"
                    onAction="#handleMoodTracker"
                    prefWidth="Infinity" prefHeight="45"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;"/>

            <Button text="&#x1F4CB;  Recommendations"
                    onAction="#handleRecommendations"
                    prefWidth="Infinity" prefHeight="45"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;"/>

            <Button text="&#x1F464;  Profile"
                    onAction="#handleProfile"
                    prefWidth="Infinity" prefHeight="45"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;"/>

            <Button text="&#x2139;  About Us"
                    prefWidth="Infinity" prefHeight="45"
                    style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Button text="&#x1F6AA;  Logout"
                    onAction="#handleLogout"
                    prefWidth="Infinity" prefHeight="45"
                    style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;"/>
        </VBox>
    </left>

    <!-- Main Content -->
    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: transparent; -fx-background: #f8fafc; -fx-border-color: transparent;">
            <VBox spacing="30" style="-fx-padding: 40 50;">

                <!-- 
                     HERO SECTION
                      -->
                <VBox spacing="12" alignment="CENTER"
                      style="-fx-background-color: linear-gradient(to right, #4f46e5, #7c3aed);
                             -fx-background-radius: 20; -fx-padding: 40 30;">
                    <Label text="&#x1F9E0;"
                           style="-fx-font-size: 48px;"/>
                    <Label text="Mental Health Analysis"
                           style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label text="AI-Powered Insights for a Healthier Mind"
                           style="-fx-font-size: 16px; -fx-text-fill: rgba(255,255,255,0.85);"/>
                    <Label text="Version 1.0  &#x2022;  FAST NUCES  &#x2022;  Software Design &amp; Analysis"
                           style="-fx-font-size: 12px; -fx-text-fill: rgba(255,255,255,0.6); -fx-padding: 8 0 0 0;"/>
                </VBox>

                <!-- 
                     THE IDEA
                      -->
                <VBox styleClass="card" spacing="12">
                    <Label text="&#x1F4A1;  The Idea"
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                    <Separator/>
                    <Label wrapText="true"
                           style="-fx-font-size: 14px; -fx-text-fill: #475569; -fx-line-spacing: 4;"
                           text="Mental health is one of the most pressing challenges of our generation, yet it remains deeply underserved by technology. We asked ourselves a simple question: What if your daily journaling could do more than just sit in a diary? What if it could actually tell you how you're feeling — before you even realize it yourself? That question became this application. By combining natural language processing with a trained machine learning model, we built a system that reads your words, understands the emotional patterns behind them, and provides real-time mental health predictions — from Normal to Stress, Anxiety, Depression, and beyond."/>
                </VBox>

                <!-- 
                     OUR MOTIVE
                      -->
                <VBox styleClass="card" spacing="12">
                    <Label text="&#x1F3AF;  Our Motive"
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                    <Separator/>
                    <Label wrapText="true"
                           style="-fx-font-size: 14px; -fx-text-fill: #475569; -fx-line-spacing: 4;"
                           text="We believe that mental health awareness should be accessible, stigma-free, and proactive — not reactive. Our motive is threefold:"/>
                    <VBox spacing="8" style="-fx-padding: 5 0 0 15;">
                        <Label wrapText="true"
                               style="-fx-font-size: 13px; -fx-text-fill: #334155;"
                               text="&#x2022;  Empower individuals to understand their emotional patterns through data, not guesswork."/>
                        <Label wrapText="true"
                               style="-fx-font-size: 13px; -fx-text-fill: #334155;"
                               text="&#x2022;  Bridge the gap between daily self-expression and clinical-grade mental health insight."/>
                        <Label wrapText="true"
                               style="-fx-font-size: 13px; -fx-text-fill: #334155;"
                               text="&#x2022;  Provide a safe, private, offline-first tool that respects user data and never compromises on privacy."/>
                    </VBox>
                    <Label wrapText="true"
                           style="-fx-font-size: 14px; -fx-text-fill: #475569; -fx-line-spacing: 4; -fx-padding: 5 0 0 0;"
                           text="This project is not a replacement for professional help — it is a companion that helps you recognize when professional help might be needed, and equips you with the self-awareness to take that step."/>
                </VBox>

                <!-- 
                     KEY FEATURES
                      -->
                <VBox styleClass="card" spacing="12">
