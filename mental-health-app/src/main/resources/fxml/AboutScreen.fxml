                            </VBox>
                        </HBox>

                        <HBox spacing="10" alignment="CENTER_LEFT" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <Label text="&#x1F9D8;" style="-fx-font-size: 22px;"/>
                            <VBox spacing="2">
                                <Label text="Wellness Tools" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                                <Label text="Breathing exercises and self-care tracking" style="-fx-font-size: 11px; -fx-text-fill: #64748b;"/>
                            </VBox>
                        </HBox>

                        <HBox spacing="10" alignment="CENTER_LEFT" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <Label text="&#x1F512;" style="-fx-font-size: 22px;"/>
                            <VBox spacing="2">
                                <Label text="Privacy-First Design" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                                <Label text="All data stored locally on your machine" style="-fx-font-size: 11px; -fx-text-fill: #64748b;"/>
                            </VBox>
                        </HBox>

                        <HBox spacing="10" alignment="CENTER_LEFT" GridPane.columnIndex="0" GridPane.rowIndex="2">
