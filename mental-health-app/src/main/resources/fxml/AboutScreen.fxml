                            <VBox spacing="2">
                                <Label text="Mood History" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                                <Label text="Full analysis history with search and filters" style="-fx-font-size: 11px; -fx-text-fill: #64748b;"/>
                            </VBox>
                        </HBox>

                        <HBox spacing="10" alignment="CENTER_LEFT" GridPane.columnIndex="1" GridPane.rowIndex="2">
                            <Label text="&#x1F6A8;" style="-fx-font-size: 22px;"/>
                            <VBox spacing="2">
                                <Label text="Crisis Resources" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                                <Label text="Dynamic helplines based on risk assessment" style="-fx-font-size: 11px; -fx-text-fill: #64748b;"/>
                            </VBox>
                        </HBox>
                    </GridPane>
                </VBox>

