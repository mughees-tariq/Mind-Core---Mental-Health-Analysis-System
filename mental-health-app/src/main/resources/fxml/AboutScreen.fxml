                        <HBox spacing="10" alignment="CENTER_LEFT" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="&#x1F916;" style="-fx-font-size: 22px;"/>
                            <VBox spacing="2">
                                <Label text="AI-Powered Predictions" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                                <Label text="NLP model trained on mental health data" style="-fx-font-size: 11px; -fx-text-fill: #64748b;"/>
                            </VBox>
                        </HBox>

                        <HBox spacing="10" alignment="CENTER_LEFT" GridPane.columnIndex="1" GridPane.rowIndex="0">
