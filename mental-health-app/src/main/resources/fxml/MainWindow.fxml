<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:id="root"
            fx:controller="com.mentalhealth.controller.MainController"
            prefWidth="1200" prefHeight="800">

    <!-- Sidebar -->
    <left>
        <VBox prefWidth="250" spacing="5"
              style="-fx-background-color: #1565C0;">
            <padding>
                <Insets top="20" right="15" bottom="20" left="15"/>
            </padding>

            <Label text="Mental Health"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>

            <Region prefHeight="30"/>

            <Button text="📊  Dashboard"
                    prefWidth="Infinity" prefHeight="45"
                    style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;"/>

            <Button text="📝  New Analysis"
                    onAction="#handleNewAnalysis"
                    prefWidth="Infinity" prefHeight="45"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;"/>

            <Button text="📜  History"
                    onAction="#handleHistory"
                    prefWidth="Infinity" prefHeight="45"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;"/>

            <Button text="😊  Mood Tracker"
                    onAction="#handleMoodTracker"
                    prefWidth="Infinity" prefHeight="45"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;"/>

            <Button text="📋  Recommendations"
                    onAction="#handleRecommendations"
                    prefWidth="Infinity" prefHeight="45"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;"/>

            <Button text="👤  Profile"
                    onAction="#handleProfile"
                    prefWidth="Infinity" prefHeight="45"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;"/>

            <Button text="ℹ️  About Us"
                    onAction="#handleAbout"
                    prefWidth="Infinity" prefHeight="45"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Button text="🚪  Logout"
                    onAction="#handleLogout"
                    prefWidth="Infinity" prefHeight="45"
                    style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;"/>
        </VBox>
    </left>

    <!-- Main Content -->
    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true"
                    style="-fx-background-color: transparent; -fx-background: #f8fafc; -fx-border-color: transparent;">
            <VBox styleClass="content-area" spacing="25">

                <!-- HEADER -->
                <HBox alignment="CENTER_LEFT">
                    <Label text="🎉 Welcome to Mental Health Analysis!"
                           style="-fx-font-size: 28px; -fx-font-weight: bold;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <HBox spacing="15" alignment="CENTER_RIGHT">
                        <!-- Notification Bell (clickable) -->
                        <VBox alignment="CENTER">
                            <Button fx:id="notificationBtn" text="🔔"
                                    onAction="#handleNotifications"
                                    style="-fx-background-color: transparent; -fx-font-size: 20px; -fx-cursor: hand; -fx-padding: 5;"/>
                            <Label fx:id="notifBadge" text=""
                                   style="-fx-text-fill: #ef4444; -fx-font-size: 10px; -fx-font-weight: bold;"
                                   managed="false" visible="false"/>
                        </VBox>
                        <Button text="👤" onAction="#handleProfile"
                                style="-fx-background-color: transparent; -fx-font-size: 20px; -fx-cursor: hand; -fx-padding: 5;"/>
                    </HBox>
                </HBox>

                <!-- DASHBOARD GRID -->
                <GridPane hgap="20" vgap="20" VBox.vgrow="ALWAYS">

                    <!-- COLUMN SETUP -->
                    <columnConstraints>
                        <ColumnConstraints percentWidth="25"/>
                        <ColumnConstraints percentWidth="25"/>
                        <ColumnConstraints percentWidth="25"/>
                        <ColumnConstraints percentWidth="25"/>
                    </columnConstraints>

                    <!-- ROW SETUP -->
                    <rowConstraints>
                        <RowConstraints minHeight="100"/>
                        <RowConstraints minHeight="120"/>
                        <RowConstraints minHeight="180" valignment="TOP"/>
                        <RowConstraints minHeight="260" valignment="TOP"/>
                    </rowConstraints>

                    <!-- ROW 0: WELCOME CARD (FULL WIDTH) -->
                    <VBox styleClass="card" spacing="4"
                          GridPane.columnSpan="4" GridPane.rowIndex="0">
                        <Label text="Mental Health Insight" styleClass="card-title"
                               style="-fx-text-fill: #607D8B; -fx-font-size: 12px;"/>
                        <Label fx:id="welcomeLabel" text="Hello! 👋"
                               style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
                        <Label fx:id="screeningLabel" text="Screening result based on current inputs"
                               style="-fx-text-fill: #757575;"/>
                    </VBox>

                    <!-- ROW 1: METRIC CARDS -->

                    <!-- Card 1: Total Analyses -->
                    <VBox styleClass="card" spacing="6"
                          fx:id="signalCard"
                          GridPane.columnIndex="0" GridPane.rowIndex="1">
                        <Label text="TOTAL ANALYSES" styleClass="card-title"
                               style="-fx-text-fill: #607D8B; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        <Label fx:id="totalAnalysesLabel" text="0"
                               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1E88E5;"/>
                        <Label text="All time" style="-fx-text-fill: #9e9e9e; -fx-font-size: 11px;"/>
                    </VBox>

                    <!-- Card 2: Streak -->
                    <VBox styleClass="card" spacing="6"
                          GridPane.columnIndex="1" GridPane.rowIndex="1">
                        <Label text="STREAK" styleClass="card-title"
                               style="-fx-text-fill: #607D8B; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        <Label fx:id="streakLabel" text="0 days"
                               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #FF9800;"/>
                        <Label text="Consecutive days" style="-fx-text-fill: #9e9e9e; -fx-font-size: 11px;"/>
                    </VBox>

                    <!-- Card 3: Dominant Mood -->
                    <VBox styleClass="card" spacing="6"
                          GridPane.columnIndex="2" GridPane.rowIndex="1">
                        <Label text="DOMINANT MOOD" styleClass="card-title"
                               style="-fx-text-fill: #607D8B; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        <Label fx:id="dominantMoodLabel" text="—"
                               style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
                        <Label text="This week" style="-fx-text-fill: #9e9e9e; -fx-font-size: 11px;"/>
                    </VBox>

                    <!-- Card 4: Risk Level -->
                    <VBox styleClass="card" spacing="6"
                          GridPane.columnIndex="3" GridPane.rowIndex="1">
                        <Label text="RISK LEVEL" styleClass="card-title"
                               style="-fx-text-fill: #607D8B; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        <Label fx:id="riskLevelLabel" text="—"
                               style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
                        <Label text="Current assessment" style="-fx-text-fill: #9e9e9e; -fx-font-size: 11px;"/>
                    </VBox>

                    <!-- ROW 2: TREND CHART + CONFIDENCE -->

                    <!-- Trend Card (3 columns) — Mood Distribution + Journey -->
                    <VBox styleClass="card" spacing="12"
                          GridPane.columnSpan="3" GridPane.rowIndex="2">
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label fx:id="trendIconLabel" text="➡️"
                                   style="-fx-font-size: 20px;"/>
                            <Label fx:id="trendTitleLabel" text="Overall Trend"
                                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="trendDescLabel" text=""
                                   style="-fx-font-size: 12px; -fx-text-fill: #64748b;"
                                   wrapText="true"/>
                        </HBox>

                        <!-- Mood Frequency Bars (built dynamically) -->
                        <VBox fx:id="moodDistContainer" spacing="8"/>

                                          <!-- Only keep mood distribution and trend -->
                                          <!-- Mood Frequency Bars (built dynamically) -->
                                          <VBox fx:id="moodDistContainer" spacing="8"/>
                    </VBox>

                    <!-- Latest Analysis Card -->
                    <VBox styleClass="card" spacing="6"
                          GridPane.columnIndex="3" GridPane.rowIndex="2">
                        <Label text="LATEST ANALYSIS" styleClass="card-title"
                               style="-fx-text-fill: #607D8B; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        <Label fx:id="latestPredLabel" text="None"
                               style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                        <Label fx:id="latestConfLabel" text="Confidence: —"
                               style="-fx-text-fill: #1E88E5; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                        <Label fx:id="latestSeverityLabel" text="Severity: —"
                               style="-fx-text-fill: #757575; -fx-font-size: 12px;"/>
                        <Region VBox.vgrow="ALWAYS"/>
                        <Button text="📝 Quick Analysis" onAction="#handleNewAnalysis"
                                prefWidth="Infinity" prefHeight="32"
                                style="-fx-background-color: #1E88E5; -fx-text-fill: white; -fx-font-size: 12px; -fx-background-radius: 8; -fx-cursor: hand;"/>
                    </VBox>

                    <!-- ROW 3: INTERACTIVE CARDS -->

                    <!-- Col 0: Breathing Exercise -->
                    <VBox styleClass="card" spacing="8"
                          fx:id="breathingCard"
                          alignment="CENTER"
                          GridPane.columnIndex="0" GridPane.rowIndex="3">
                        <Label text="&#x1F9D8; BREATHING EXERCISE"
                               style="-fx-text-fill: #607D8B; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        <StackPane fx:id="breathingCircleContainer"
                                   alignment="CENTER" prefHeight="100" prefWidth="100"/>
                        <Label fx:id="breathingPhaseLabel" text="Press Start"
                               style="-fx-font-size: 13px; -fx-text-fill: #64748b; -fx-font-weight: bold;"
                               alignment="CENTER"/>
                        <Button fx:id="breathingToggleBtn" text="&#x25B6;  Start"
                                onAction="#handleBreathingToggle"
                                prefWidth="Infinity" prefHeight="32"
                                style="-fx-background-color: #4f46e5; -fx-text-fill: white;
                                       -fx-font-size: 12px; -fx-background-radius: 8; -fx-cursor: hand;"/>
                    </VBox>

                    <!-- Col 1: Daily Mental Health Tip -->
                    <VBox styleClass="card" spacing="8"
                          GridPane.columnIndex="1" GridPane.rowIndex="3">
                        <HBox spacing="6" alignment="CENTER_LEFT">
                            <Label text="&#x1F4A1; DAILY TIP"
                                   style="-fx-text-fill: #607D8B; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="tipMoodLabel" text=""
                                   style="-fx-font-size: 10px; -fx-text-fill: white; -fx-background-color: #6366f1;
                                          -fx-padding: 2 8; -fx-background-radius: 10;"/>
                        </HBox>
                        <Label fx:id="dailyTipLabel" text="Loading tip..."
                               wrapText="true"
                               style="-fx-font-size: 12px; -fx-text-fill: #1e293b; -fx-line-spacing: 2;"/>
                        <Region VBox.vgrow="ALWAYS"/>
                        <Button fx:id="tipRefreshBtn" text="&#x1F504;  New Tip"
                                onAction="#handleRefreshTip"
                                prefWidth="Infinity" prefHeight="30"
                                style="-fx-background-color: #e0f2fe; -fx-text-fill: #0369a1;
                                       -fx-font-size: 11px; -fx-background-radius: 8; -fx-cursor: hand;"/>
                    </VBox>

                    <!-- Col 2: Self-Care Checklist -->
                    <VBox styleClass="card" spacing="6"
                          GridPane.columnIndex="2" GridPane.rowIndex="3">
                        <HBox spacing="6" alignment="CENTER_LEFT">
                            <Label text="&#x2705; SELF-CARE TODAY"
                                   style="-fx-text-fill: #607D8B; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="selfCareCountLabel" text="0 / 5"
                                   style="-fx-font-size: 11px; -fx-text-fill: #10b981; -fx-font-weight: bold;"/>
                        </HBox>
                        <CheckBox fx:id="checkSleep" text="&#x1F634;  Slept 7+ hours"
                                  onAction="#handleChecklistToggle" style="-fx-font-size: 12px;"/>
                        <CheckBox fx:id="checkWater" text="&#x1F4A7;  Drank enough water"
                                  onAction="#handleChecklistToggle" style="-fx-font-size: 12px;"/>
                        <CheckBox fx:id="checkExercise" text="&#x1F3C3;  Exercised"
                                  onAction="#handleChecklistToggle" style="-fx-font-size: 12px;"/>
                        <CheckBox fx:id="checkOutside" text="&#x1F333;  Went outside"
                                  onAction="#handleChecklistToggle" style="-fx-font-size: 12px;"/>
                        <CheckBox fx:id="checkSocial" text="&#x1F91D;  Talked to someone"
                                  onAction="#handleChecklistToggle" style="-fx-font-size: 12px;"/>
                    </VBox>

                    <!-- Col 3: Community Resources -->
                    <VBox styleClass="card" spacing="6"
                          GridPane.columnIndex="3" GridPane.rowIndex="3">
                        <Label text="&#x1F6A8; CRISIS RESOURCES"
                               style="-fx-text-fill: #607D8B; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        <VBox fx:id="resourceContainer" spacing="4"/>
                    </VBox>

                </GridPane>

                <!-- NOTIFICATION PANEL (hidden by default, toggled by bell) -->
                <VBox fx:id="notificationPanel" spacing="8" visible="false" managed="false"
                      style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.12), 12, 0, 0, 4);">
                    <Label text="🔔 Notifications"
                           style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                    <Separator/>
                    <VBox fx:id="notifContainer" spacing="6">
                        <!-- Notification items added dynamically -->
                    </VBox>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
