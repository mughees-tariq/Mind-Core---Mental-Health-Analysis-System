<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.mentalhealth.controller.RegisterController"
            prefWidth="1200" prefHeight="800"
            stylesheets="@../css/styles.css">

    <!--  LEFT  BRAND  PANEL    -->
    <left>
        <VBox prefWidth="360" styleClass="login-left" alignment="TOP_LEFT" spacing="0">
            <padding>
                <Insets top="48" right="36" bottom="48" left="36"/>
            </padding>

            <Label text="Mental Health" styleClass="login-left-title"/>
            <Label text="AI-powered mental wellness companion"
                   styleClass="login-left-subtitle"
                   style="-fx-padding: 4 0 0 0;"/>

            <Region prefHeight="48"/>

            <Label text="Begin your wellness&#10;journey today."
                   wrapText="true"
                   style="-fx-font-size: 26px; -fx-font-weight: bold;
                          -fx-text-fill: white; -fx-line-spacing: 4;"/>

            <Label text="Create your account in under a minute and get personalised mental health insights powered by AI."
                   wrapText="true"
                   style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.75);
                          -fx-line-spacing: 3; -fx-padding: 14 0 0 0;"/>

            <Region prefHeight="32"/>

            <VBox spacing="11">
     <HBox spacing="16" alignment="CENTER_LEFT" 
      styleClass="register-feature-card"
      maxWidth="Infinity">
    <padding>
        <Insets left="16" right="16" top="12" bottom="12"/>
    </padding>
    <Label text="📊" style="-fx-font-size: 22px;"/>
    <VBox spacing="2">
        <Label text="Daily Mood Tracking"
               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        <Label text="Log your emotions in seconds"
               style="-fx-font-size: 11px; -fx-text-fill: rgba(255,255,255,0.65);"/>
    </VBox>
    </HBox>
                <HBox spacing="16" alignment="CENTER_LEFT" styleClass="register-feature-card">
                    <Label text="🤖" style="-fx-font-size: 22px;"/>
                    <VBox spacing="2">
                        <Label text="AI-Powered Insights"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Personalised recommendations daily"
                               style="-fx-font-size: 11px; -fx-text-fill: rgba(255,255,255,0.65);"/>
                    </VBox>
                </HBox>
                <HBox spacing="16" alignment="CENTER_LEFT" styleClass="register-feature-card">
                    <Label text="📈" style="-fx-font-size: 22px;"/>
                    <VBox spacing="2">
                        <Label text="Progress Analytics"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Visualise your wellness over time"
                               style="-fx-font-size: 11px; -fx-text-fill: rgba(255,255,255,0.65);"/>
                    </VBox>
                </HBox>
                <HBox spacing="16" alignment="CENTER_LEFT" styleClass="register-feature-card">
                    <Label text="🔒" style="-fx-font-size: 22px;"/>
                    <VBox spacing="2">
                        <Label text="100% Private &amp; Secure"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Your data is yours — always"
                               style="-fx-font-size: 11px; -fx-text-fill: rgba(255,255,255,0.65);"/>
                    </VBox>
                </HBox>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <Label text="Track  •  Analyse  •  Improve"
                   styleClass="login-left-footnote"
                   style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
        </VBox>
    </left>

    <!--  RIGHT  FORM  PANEL -->
    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: transparent; -fx-background: #f8fafc;
                           -fx-border-color: transparent;">
            <VBox alignment="CENTER" style="-fx-background-color: #f8fafc;">
                <padding>
                    <Insets top="32" right="52" bottom="32" left="52"/>
                </padding>

                <VBox spacing="0" maxWidth="540" styleClass="card register-card">

                    <!-- Coloured header band -->
                    <VBox styleClass="register-card-header" spacing="5">
                        <Label text="✨  Create Your Account"
                               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                        <Label text="Fill in the details below — takes less than a minute."
                               style="-fx-font-size: 13px; -fx-text-fill: #64748b;"/>
                    </VBox>

                    <!-- Form body -->
                    <VBox spacing="18" style="-fx-padding: 26 30 30 30;">

                        <!-- Error / Success message — fx:id PRESERVED -->
                        <Label fx:id="messageLabel"
                               wrapText="true"
                               styleClass="register-message-label"
                               visible="false" managed="false"/>

                        <!-- REQUIRED section badge -->
                        <HBox alignment="CENTER_LEFT">
                            <Label text="REQUIRED DETAILS"
                                   styleClass="register-section-badge register-section-badge-blue"/>
                        </HBox>

                        <!-- Username + Full Name side-by-side -->
                        <GridPane hgap="14">
                            <columnConstraints>
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                            </columnConstraints>
                            <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <Label text="Username *" styleClass="form-label"/>
                                <TextField fx:id="usernameField"
                                           promptText="e.g. john_doe"
                                           prefHeight="44"
                                           styleClass="register-input"/>
                            </VBox>
                            <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <Label text="Full Name *" styleClass="form-label"/>
                                <TextField fx:id="nameField"
                                           promptText="Your full name"
                                           prefHeight="44"
                                           styleClass="register-input"/>
                            </VBox>
                        </GridPane>

                        <!-- Password with strength indicator -->
                        <VBox spacing="6">
                            <Label text="Password *" styleClass="form-label"/>
                            <HBox spacing="10" alignment="CENTER">
                                <PasswordField fx:id="passwordField"
                                               promptText="Min 8 chars, letters &amp; numbers"
                                               prefHeight="44" HBox.hgrow="ALWAYS"
                                               styleClass="register-input"/>
                                <TextField fx:id="passwordFieldVisible"
                                           promptText="Min 8 chars, letters &amp; numbers"
                                           prefHeight="44" HBox.hgrow="ALWAYS"
                                           styleClass="register-input"
                                           visible="false" managed="false"/>
                                <CheckBox fx:id="showPasswordCheck"
                                          text="👁"
                                          onAction="#togglePasswordVisibility"
                                          style="-fx-cursor: hand; -fx-font-size: 16px;"/>
                            </HBox>
                            <!-- Strength bar row (wired in updated controller) -->
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <ProgressBar fx:id="passwordStrengthBar"
                                             progress="0"
                                             prefHeight="6" prefWidth="180"
                                             styleClass="register-strength-weak"/>
                                <Label fx:id="passwordStrengthLabel"
                                       text=""
                                       style="-fx-font-size: 11px; -fx-font-weight: bold;"/>
                            </HBox>
                        </VBox>

                        <!-- Confirm Password -->
                        <VBox spacing="6">
                            <Label text="Confirm Password *" styleClass="form-label"/>
                            <HBox spacing="10" alignment="CENTER">
                                <PasswordField fx:id="confirmPasswordField"
                                               promptText="Re-enter your password"
                                               prefHeight="44" HBox.hgrow="ALWAYS"
                                               styleClass="register-input"/>
                                <TextField fx:id="confirmPasswordFieldVisible"
                                           promptText="Re-enter your password"
                                           prefHeight="44" HBox.hgrow="ALWAYS"
                                           styleClass="register-input"
                                           visible="false" managed="false"/>
                                <CheckBox fx:id="showConfirmPasswordCheck"
                                          text="👁"
                                          onAction="#toggleConfirmPasswordVisibility"
                                          style="-fx-cursor: hand; -fx-font-size: 16px;"/>
                            </HBox>
                        </VBox>

                        <!-- Age (required) -->
                        <VBox spacing="4">
                            <Label text="Age *" styleClass="form-label"/>
                            <TextField fx:id="ageField"
                                       promptText="e.g. 24"
                                       prefHeight="44"
                                       maxWidth="160"
                                       styleClass="register-input"/>
                            <Label fx:id="ageErrorLabel"
                                   text=""
                                   visible="false" managed="false"
                                   style="-fx-text-fill: #ef4444; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        </VBox>

                        <!--  section divider -->
                        <HBox alignment="CENTER" spacing="14" style="-fx-padding: 2 0 0 0;">
                            <Region HBox.hgrow="ALWAYS"
                                    style="-fx-background-color: #e2e8f0; -fx-min-height: 1px; -fx-max-height: 1px;"/>
                            <Label text="OPTIONAL DETAILS"
                                   styleClass="register-section-badge register-section-badge-teal"/>
                            <Region HBox.hgrow="ALWAYS"
                                    style="-fx-background-color: #e2e8f0; -fx-min-height: 1px; -fx-max-height: 1px;"/>
                        </HBox>

                        <!-- Mental Health Goal -->
                        <VBox spacing="6">
                            <Label text="Mental Health Goal" styleClass="form-label"/>
                            <TextArea fx:id="goalField"
                                      promptText="What do you hope to achieve?"
                                      prefRowCount="2" wrapText="true"
                                      styleClass="register-input"/>
                        </VBox>

                        <!-- Stress Level panel -->
                        <VBox spacing="10" styleClass="register-stress-panel">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label text="🌡️" style="-fx-font-size: 18px;"/>
                                <Label text="Baseline Stress Level"
                                       styleClass="form-label" HBox.hgrow="ALWAYS"
                                       style="-fx-text-fill: #1565C0; -fx-font-size: 13px;"/>
                                <StackPane styleClass="register-stress-badge">
                                    <Label fx:id="stressValueLabel" text="5"
                                           style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                                </StackPane>
                            </HBox>
                            <Slider fx:id="baselineStressSlider"
                                    min="1" max="10" value="5"
                                    showTickLabels="true" showTickMarks="true"
                                    majorTickUnit="1" minorTickCount="0"
                                    blockIncrement="1"/>
                            <HBox>
                                <Label text="😌  Calm"
                                       style="-fx-font-size: 11px; -fx-text-fill: #10b981; -fx-font-weight: bold;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label text="😰  Stressed"
                                       style="-fx-font-size: 11px; -fx-text-fill: #ef4444; -fx-font-weight: bold;"/>
                            </HBox>
                        </VBox>

                        <!-- Gender + Location side-by-side -->
                        <GridPane hgap="14">
                            <columnConstraints>
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                            </columnConstraints>
                            <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <Label text="Gender" styleClass="form-label"/>
                                <ComboBox fx:id="genderField"
                                          promptText="Select gender"
                                          prefHeight="44"
                                          styleClass="register-input">
                                    <items>
                                        <FXCollections fx:factory="observableArrayList">
                                            <String fx:value="Prefer not to say"/>
                                            <String fx:value="Male"/>
                                            <String fx:value="Female"/>
                                            <String fx:value="Other"/>
                                        </FXCollections>
                                    </items>
                                </ComboBox>
                            </VBox>
                            <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <Label text="Location" styleClass="form-label"/>
                                <TextField fx:id="locationField"
                                           promptText="e.g. New York, USA"
                                           prefHeight="44"
                                           styleClass="register-input"/>
                            </VBox>
                        </GridPane>

                        <!-- Security Question -->
                        <VBox spacing="6">
                            <Label text="Security Question *" styleClass="form-label"/>
                            <ComboBox fx:id="securityQuestionField"
                                      promptText="Choose a security question"
                                      prefHeight="44"
                                      styleClass="register-input">
                                <items>
                                    <FXCollections fx:factory="observableArrayList">
                                        <String fx:value="What is the name of your first pet?"/>
                                        <String fx:value="What was your first car?"/>
                                        <String fx:value="In what city were you born?"/>
                                        <String fx:value="What is your mother's maiden name?"/>
                                        <String fx:value="What was the name of your first school?"/>
                                        <String fx:value="What is your favorite book?"/>
                                        <String fx:value="What was your childhood nickname?"/>
                                        <String fx:value="What country have you always wanted to visit?"/>
                                    </FXCollections>
                                </items>
                            </ComboBox>
                        </VBox>

                        <!-- Security Answer -->
                        <VBox spacing="6">
                            <Label text="Security Answer *" styleClass="form-label"/>
                            <TextField fx:id="securityAnswerField"
                                       promptText="Enter your security answer"
                                       prefHeight="44"
                                       styleClass="register-input"/>
                            <Label text="💡 Answers are case-insensitive and trimmed for consistency"
                                   style="-fx-font-size: 11px; -fx-text-fill: #64748b; -fx-font-weight: normal;"/>
                        </VBox>

                        <!-- CTA Button  -->
                        <Button text="🚀   Create My Account"
                                onAction="#handleRegister"
                                maxWidth="Infinity" prefHeight="50"
                                styleClass="register-cta-button"
                                style="-fx-font-size: 15px;"/>

                        <!-- Back to login  -->
                        <HBox alignment="CENTER" spacing="6" style="-fx-padding: 2 0 0 0;">
                            <Label text="Already have an account?"
                                   style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
                            <Hyperlink text="Sign In →"
                                       onAction="#handleBackToLogin"
                                       styleClass="login-link"
                                       style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
                        </HBox>

                    </VBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
